2px);\n  overflow-y: auto;\n  overflow-x: hidden;\n  top: 0;\n}\n\n:root [data-body-theme=\"canvas\"] #fern-toc:has(\u003e *) {\n  margin-right: 12px;\n}\n\n:root [data-body-theme=\"canvas\"] .fern-layout-guide,\n:root [data-body-theme=\"canvas\"] .fern-layout-overview {\n  width: 100%;\n  border: none;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  position: relative;\n}\n\n:root [data-body-theme=\"canvas\"] .fern-layout-reference {\n  width: 100%;\n  border: none;\n  display: flex;\n  justify-content: center;\n  align-items: flex-start;\n  position: relative;\n}\n\n        /*\n * Sarvam Docs — system-level CSS token overrides\n *\n * All changes are made at the :root / .dark variable level.\n * No component selectors. Every Fern component inherits these automatically.\n */\n\n/* ─── Font face declarations ──────────────────────────────────────────────── */\n/*\n * Fern's generated @font-face only sets the first weight value (e.g. 100)\n * from docs.yml and uses format('woff2'). This caps the variable font axis,\n * making font-weight values above 100 clamp to 100 in production.\n *\n * We override with format('woff2-variations') and the full weight range.\n * The /_local/ URL works in dev; the CDN URL is inlined at build time via\n * the data-fern-font attribute Fern injects — we reference both so one\n * always resolves.\n */\n\n@font-face {\n    font-family: 'Matter';\n    src: url('/_local/Users/adithnarein/Documents/Projects/sarvam-fern-config/fern/fonts/MatterUprights-VF.woff2') format('woff2-variations');\n    font-weight: 100 1000;\n    font-style: normal;\n    font-display: swap;\n}\n\n@font-face {\n    font-family: 'Season Mix';\n    src: url('/_local/Users/adithnarein/Documents/Projects/sarvam-fern-config/fern/fonts/SeasonMixVFUprights.woff2') format('woff2-variations');\n    font-weight: 300 900;\n    font-style: normal;\n    font-display: swap;\n}\n\n@font-face {\n    font-family: 'Matter Semi Mono';\n    src: url('/_local/Users/adithnarein/Documents/Projects/sarvam-fern-config/fern/fonts/MatterSemiMonoRegular.woff2') format('woff2');\n    font-weight: 400;\n    font-style: normal;\n    font-display: swap;\n}\n\n/*\n * Production override: Fern uploads fonts to files.buildwithfern.com with a\n * content-hash prefix. We can't hardcode that URL, so we re-declare the same\n * font families pointing at the same filenames with format('woff2-variations')\n * and the full weight range. Since these declarations come AFTER Fern's\n * injected \u003cstyle\u003e block, they win on specificity by source order.\n * The `unicode-range` descriptor is omitted so these catch-all rules override.\n */\n\n/* ─── Light mode ──────────────────────────────────────────────────────────── */\n\n:root,\n.light {\n    /* Matter variable font weight scale (matches sarvamai-website) */\n    --font-weight-thin:      100;\n    --font-weight-light:     325;\n    --font-weight-normal:    425;\n    --font-weight-medium:    525;\n    --font-weight-semibold:  625;\n    --font-weight-bold:      725;\n    --font-weight-extrabold: 900;\n    --font-weight-black:     1000;\n\n    /* Text hierarchy */\n    --text-primary:   var(--grayscale-12);\n    --text-secondary: var(--grayscale-a11);\n    --text-muted:     var(--grayscale-a9);\n\n    /* Secondary text opacity for light mode */\n    --grayscale-a11: rgba(0, 0, 0, 0.85);\n\n    /* Scrollbar */\n    --accent-track: var(--grayscale-a6);\n\n    /* Shadows */\n    --shadow-sm:  0 1px 2px var(--grayscale-a3);\n    --shadow-md:  0 4px 12px var(--grayscale-a4);\n    --shadow-lg:  0 8px 24px var(--grayscale-a5), 0 2px 8px var(--grayscale-a3);\n\n    /* Borders */\n    --border-default: var(--border);\n\n    /* Decouple hover and focus from accent — use neutral grayscale instead */\n    --hover-bg:      var(--grayscale-a3);\n    --hover-bg-dark: var(--grayscale-a4);\n    --focus-ring:    var(--grayscale-a7);\n\n    /* Card icons — use muted grayscale instead of accent */\n    --fa-icon-dark: var(--grayscale-a11);\n\n    /* CTA button color — orange, independent of accent */\n    --cta-bg:          linear-gradient(135deg, #EA580C 0%, #C2410C 100%);\n    --cta-bg-hover:    linear-gradient(135deg, #C2410C 0%, #9A3412 100%);\n    --cta-text:        #ffffff;\n}\n\n/* ─── Dark mode ───────────────────────────────────────────────────────────── */\n\n.dark {\n    /* Scrollbar is more visible in dark mode */\n    --accent-track: var(--grayscale-a6);\n\n    /* CTA button — slightly brighter orange in dark mode */\n    --cta-bg:       linear-gradient(135deg, #F97316 0%, #EA580C 100%);\n    --cta-bg-hover: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);\n\n    /* Shadows should be near-invisible in dark mode — surfaces define depth */\n    --shadow-sm:  0 1px 2px var(--grayscale-a2);\n    --shadow-md:  0 2px 8px var(--grayscale-a3);\n    --shadow-lg:  0 4px 16px var(--grayscale-a4);\n\n    /* Secondary text — grayer than Fern's default #ffffffaf */\n    --grayscale-a11: rgba(255, 255, 255, 0.7);\n}\n\n/* ─── Typography — Matter weight scale ────────────────────────────────────── */\n/*\n * Remap Tailwind font-weight utilities to Matter VF's optical axis stops.\n * Tailwind uses standard CSS values (400, 600, 700) which don't land on\n * Matter's intended optical weights.\n */\n\n.font-thin       { font-weight: 100 !important; }\n.font-extralight { font-weight: 200 !important; }\n.font-light      { font-weight: 325 !important; }\n.font-normal     { font-weight: 480 !important; }\n.font-medium     { font-weight: 525 !important; }\n.font-semibold   { font-weight: 625 !important; }\n.font-bold       { font-weight: 725 !important; }\n.font-extrabold  { font-weight: 900 !important; }\n.font-black      { font-weight: 1000 !important; }\n\nbody {\n    font-weight: 425 !important;\n}\n\n/* Prose body text — secondary color, does NOT cascade to headings */\n.fern-prose p,\n.fern-prose li,\n.fern-prose td,\n.fern-prose blockquote {\n    font-weight: 425 !important;\