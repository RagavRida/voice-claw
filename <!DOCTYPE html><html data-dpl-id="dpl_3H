/*
 * Production override: Fern uploads fonts to files.buildwithfern.com with a
 * content-hash prefix. We can't hardcode that URL, so we re-declare the same
 * font families pointing at the same filenames with format('woff2-variations')
 * and the full weight range. Since these declarations come AFTER Fern's
 * injected <\73 tyle> block, they win on specificity by source order.
 * The `unicode-range` descriptor is omitted so these catch-all rules override.
 */

/* ─── Light mode ──────────────────────────────────────────────────────────── */

:root,
.light {
    /* Matter variable font weight scale (matches sarvamai-website) */
    --font-weight-thin:      100;
    --font-weight-light:     325;
    --font-weight-normal:    425;
    --font-weight-medium:    525;
    --font-weight-semibold:  625;
    --font-weight-bold:      725;
    --font-weight-extrabold: 900;
    --font-weight-black:     1000;

    /* Text hierarchy */
    --text-primary:   var(--grayscale-12);
    --text-secondary: var(--grayscale-a11);
    --text-muted:     var(--grayscale-a9);

    /* Secondary text opacity for light mode */
    --grayscale-a11: rgba(0, 0, 0, 0.85);

    /* Scrollbar */
    --accent-track: var(--grayscale-a6);

    /* Shadows */
    --shadow-sm:  0 1px 2px var(--grayscale-a3);
    --shadow-md:  0 4px 12px var(--grayscale-a4);
    --shadow-lg:  0 8px 24px var(--grayscale-a5), 0 2px 8px var(--grayscale-a3);

    /* Borders */
    --border-default: var(--border);

    /* Decouple hover and focus from accent — use neutral grayscale instead */
    --hover-bg:      var(--grayscale-a3);
    --hover-bg-dark: var(--grayscale-a4);
    --focus-ring:    var(--grayscale-a7);

    /* Card icons — use muted grayscale instead of accent */
    --fa-icon-dark: var(--grayscale-a11);

    /* CTA button color — orange, independent of accent */
    --cta-bg:          linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
    --cta-bg-hover:    linear-gradient(135deg, #C2410C 0%, #9A3412 100%);
    --cta-text:        #ffffff;
}

/* ─── Dark mode ───────────────────────────────────────────────────────────── */

.dark {
    /* Scrollbar is more visible in dark mode */
    --accent-track: var(--grayscale-a6);

    /* CTA button — slightly brighter orange in dark mode */
    --cta-bg:       linear-gradient(135deg, #F97316 0%, #EA580C 100%);
    --cta-bg-hover: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);

    /* Shadows should be near-invisible in dark mode — surfaces define depth */
    --shadow-sm:  0 1px 2px var(--grayscale-a2);
    --shadow-md:  0 2px 8px var(--grayscale-a3);
    --shadow-lg:  0 4px 16px var(--grayscale-a4);

